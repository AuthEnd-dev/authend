{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@authend/shared": ["./packages/shared/src/index.ts"],
      "@authend/sdk": ["./packages/sdk/src/index.ts"]
    }
  }
}
