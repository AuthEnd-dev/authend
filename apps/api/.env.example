NODE_ENV=development
APP_NAME=AuthEnd
APP_URL=http://localhost:7002
ADMIN_URL=http://localhost:7001
ADMIN_DEV_URL=http://localhost:7001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/authend
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_NAME=AuthEnd Admin
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AuthEnd <no-reply@example.com>
# Optional: used when Email settings → Provider is Resend (if not stored in settings)
# RESEND_API_KEY=re_...
# Comma-separated list of allowed browser origins for /api CORS and Better Auth
CORS_ORIGIN=http://localhost:7001
# CORS_ORIGIN=http://localhost:7001,https://app.example.com
OPENAI_API_KEY=

